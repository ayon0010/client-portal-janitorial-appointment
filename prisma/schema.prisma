// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client"
  output        = "../src/generated"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

type AdditionalState {
  state    String
  city     String
  zipCodes String[]
}

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  firstName   String
  lastName    String
  companyName String

  website String?

  dncList String?

  additionalStates AdditionalState[]

  contactNumber  String
  whatsappNumber String?

  receiveLeads ReceiveLeads

  years Int

  email          String @unique
  hashedPassword String

  leadNumber Int
  note       String?
  requirment String?

  max String?

  avatar String? // ImageBB URL

  status   Status  @default(ACTIVE)
  contract Boolean
  payment  Boolean

  issue String?

  licensed Boolean

  leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  lead String @db.String

  paymentStatus PaymentStatus @default(pending)

  assignedUserId String @db.ObjectId
  assignedUser   User   @relation(fields: [assignedUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentStatus {
  paid
  unpaid
  pending
}

enum ReceiveLeads {
  email
  whatsapp
}

enum Status {
  ACTIVE
  DEACTIVE
  HOLD
}
